# Database
POSTGRES_USER=fitstyle
POSTGRES_PASSWORD=fitstyle_secret
POSTGRES_DB=fitstyle_crm
DATABASE_URL=postgresql+asyncpg://fitstyle:fitstyle_secret@localhost:5432/fitstyle_crm
SYNC_DATABASE_URL=postgresql://fitstyle:fitstyle_secret@localhost:5432/fitstyle_crm

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# AI Provider: "groq" or "openai"
AI_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key
OPENAI_API_KEY=your-openai-api-key

# Channel Service
CHANNEL_SERVICE_URL=http://localhost:8001
CRM_CALLBACK_URL=http://localhost:8000/api/campaign-events
